# ---------------------------------------------------------------------------
# AI Personal Assistant - Environment Variables (frontend)
# Copy this file to ".env" and fill in real values. Never commit ".env".
# ---------------------------------------------------------------------------

# Base URL of the n8n instance that hosts all automation webhooks
VITE_N8N_BASE_URL=https://wifi-recapture-gangly.ngrok-free.dev/webhook

# n8n webhook paths (kept separate so they can be renamed independently)
VITE_N8N_CHAT_PATH=/assistant/chat
VITE_N8N_NEARBY_BUSINESS_PATH=/assistant/nearby-business
VITE_N8N_CALL_PATH=/assistant/call
VITE_N8N_SAVE_LOG_PATH=/assistant/save-log

# Google Maps JavaScript/Places API key (browser-restricted key)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Future-ready: Django REST Framework backend (unused until backend goes live)
VITE_DJANGO_API_BASE_URL=http://localhost:8000/api

# Feature flags
VITE_USE_LOCAL_STORAGE_FALLBACK=true
